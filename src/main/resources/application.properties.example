# MySQL Configuration
spring.datasource.url=jdbc:mysql://localhost:3306/EVENTMANAGEMENT?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
spring.datasource.username=YOUR_USERNAME
spring.datasource.password=YOUR_PASSWORD

# JPA / Hibernate
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=true

# Server Configuration
server.port=7070

# JWT Configuration
jwt.secret=YOUR_JWT_SECRET
jwt.expiration=86400000

# CORS Configuration
spring.web.cors.allowed-origins=http://localhost:5500,http://127.0.0.1:5500,http://localhost:7070,http://127.0.0.1:7070,http://localhost:9090,http://127.0.0.1:9090
spring.web.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS
spring.web.cors.allowed-headers=*
spring.web.cors.allow-credentials=true

# AI Configuration
openai.api.key=YOUR_OPENAI_API_KEY
openai.api.url=https://api.openai.com/v1/chat/completions
